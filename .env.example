# All optional: with everything unset the app runs in demo mode (mock email
# sign-in + localStorage portfolio). Fill in at deploy time.

# --- Central auth (Clerk on worldstreetgold.com) ---
# Same Clerk application as the other WorldStreet platforms. Setting the
# publishable key switches the app from mock auth to Clerk satellite SSO.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Defaults baked into lib/auth-config.ts; override only if they change.
# NEXT_PUBLIC_CLERK_DOMAIN=worldstreetgold.com
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=https://www.worldstreetgold.com/login

# --- Prediction backend (services/api) ---
# e.g. https://prediction-api.worldstreetgold.com — unset = mock cash/portfolio.
NEXT_PUBLIC_API_URL=
