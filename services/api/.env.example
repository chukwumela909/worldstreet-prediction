# --- Server ---
NODE_ENV=development
HOST=0.0.0.0
PORT=3001
LOG_LEVEL=info
# Set true behind Coolify/Traefik so rate limiting sees real client IPs.
TRUST_PROXY=false

# --- Database (this platform's own data; NOT the wallet's DB) ---
MONGODB_URI=mongodb+srv://...
MONGODB_DB_NAME=worldstreet-prediction

# --- Central auth (Clerk on worldstreetgold.com) ---
# Same Clerk application as the other WorldStreet platforms — copy the
# publishable + secret key from e.g. xtreme-livestream's services/api env.
CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
# Origins allowed as `azp` in session JWTs. Comma-separated.
CLERK_AUTHORIZED_PARTIES=https://worldstreetgold.com,https://www.worldstreetgold.com,https://prediction.worldstreetgold.com,http://localhost:3000

# Extra CORS origins on top of the built-in first-party list. Comma-separated.
CORS_ORIGINS=

# --- Central wallet service ---
# Leave both unset to boot without money features (wallet routes return 503).
WALLET_API_URL=https://wallet-api.worldstreetgold.com
# Service-principal token: the `prediction:<token>` entry that must be added
# to the wallet service's WALLET_SERVICE_TOKENS env. Server-side only, never
# expose to a browser or mobile client.
WALLET_SERVICE_TOKEN=

# --- Rate limiting ---
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW=1 minute
